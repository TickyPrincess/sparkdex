# SparkDex runtime
NEXT_PUBLIC_APP_NAME=SparkDex
NEXT_PUBLIC_DEFAULT_PROVIDER=mock-demo

# Provider toggles
SPARKDEX_PROVIDER_MOCK=true
SPARKDEX_PROVIDER_EBAY=false
SPARKDEX_PROVIDER_TCG=false
SPARKDEX_PROVIDER_HISTORY=false
SPARKDEX_PROVIDER_CSV=true

# Optional provider credentials (never commit real keys)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
TCG_API_KEY=
PRICE_HISTORY_API_KEY=

# Optional telemetry
SPARKDEX_ENABLE_TELEMETRY=false
